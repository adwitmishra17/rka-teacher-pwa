# ── Server-side env vars (NEVER commit real values) ──────────────────────────

# Firebase Admin SDK service account (full JSON, single line).
# Download from Firebase Console → Project settings → Service accounts.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Supabase project URL and service-role key.
# Dashboard → Project Settings → API → URL / service_role.
# The service-role key bypasses RLS — keep it server-side only.
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Port the Express server listens on (default: 3001).
PORT=3001

# Allowed CORS origin(s). Comma-separated. Omit to allow all (dev only).
# CORS_ORIGIN=https://teacher.rkacademyballia.in

# Node env — set to "production" in Hostinger.
NODE_ENV=development
